SQLITECLOUD_ADMIN_URL=sqlitecloud://user:password@host.sqlite.cloud:8860
SQLITECLOUD_DB_NAME=lotusia
SQLITECLOUD_DB_URL=sqlitecloud://user:password@host.sqlite.cloud:8860/lotusia
# Alternative auth mode:
# SQLITECLOUD_HOST=host.sqlite.cloud:8860
# SQLITECLOUD_API_KEY=your_sqlite_cloud_api_key

# Lotus blockchain API upstream (node/indexer endpoint).
LOTUS_API_BASE_URL=https://your-lotus-api-base

# Chronik endpoint used by high-throughput backfill (default if unset: https://chronik.lotusia.org)
CHRONIK_BASE_URL=https://chronik.lotusia.org

# Optional auth token if upstream requires it.
LOTUS_API_AUTH_TOKEN=

# API fallback upstreams used when local DB has cache misses.
FALLBACK_EXPLORER_API_BASE=https://explorer.lotusia.org
FALLBACK_SOCIAL_API_BASE=
ENABLE_SOCIAL_FALLBACK=false
EXPLORER_FALLBACK_BASE=https://explorer.lotusia.org

# API server port for local validation.
PORT=8788

# Demo worker -> SQLite function router.
SQLITE_EDGE_FUNCTIONS_BASE=https://your-project.g1.sqlite.cloud:443/v2/functions
SQLITE_EDGE_FUNCTIONS_API_KEY=your_sqlite_cloud_api_key
